@model SalesWeb.Communication.Responses.SellerResponses.ResponseSellerJson

@{
    ViewData["Title"] = "Delete Seller";
}

<h2>Delete Seller</h2>

<h4>Are you sure you want to delete this seller?</h4>

<hr />

<dl>
    <dt>Name</dt>
    <dd>@Model.Name</dd>

    <dt>Email</dt>
    <dd>@Model.Email</dd>

    <dt>Birth Date</dt>
    <dd>@Model.BirthDate.ToShortDateString()</dd>

    <dt>Base Salary</dt>
    <dd>@Model.BaseSalary</dd>

    <dt>Department</dt>
    <dd>@Model.DepartmentName</dd>
</dl>

<form asp-action="DeleteConfirmed" method="post">

    <input type="hidden" asp-for="Id" />

    @Html.AntiForgeryToken()

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>