@model SalesWeb.Communication.Responses.DepartmentResponses.Details.ResponseDepartmentDetailsJson

@{
    ViewData["Title"] = "Department Details";
}

<h2>Department Details</h2>

<hr />

<dl class="row">
    <dt class="col-sm-3">
        Name
    </dt>

    <dd class="col-sm-9">
        @Model.Name
    </dd>
</dl>

<h4 class="mt-4">Sellers</h4>

@if (Model.Sellers.Any())
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Birth Date</th>
                <th>Base Salary</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var seller in Model.Sellers)
            {
                <tr>
                    <td>@seller.Name</td>
                    <td>@seller.Email</td>
                    <td>@seller.BirthDate.ToString("dd/MM/yyyy")</td>
                    <td>@seller.BaseSalary.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">
        This department has no sellers.
    </p>
}

<div class="mt-3">
    <a asp-action="Edit"
       asp-route-id="@Model.Id"
       class="btn btn-warning">
        Edit
    </a>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back to List
    </a>
</div>