@model SalesWeb.Communication.Responses.DepartmentResponses.ResponseDepartmentJson

@{
    ViewData["Title"] = "Department Details";
}

<h2>Department Details</h2>

<hr />

<dl class="row">

    <dt class="col-sm-3">
        Name
    </dt>

    <dd class="col-sm-9">
        @Model.Name
    </dd>

</dl>

<div class="mt-3">

    <a asp-action="Edit"
       asp-route-id="@Model.Id"
       class="btn btn-warning">
        Edit
    </a>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back to List
    </a>

</div>